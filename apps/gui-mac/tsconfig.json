{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["node", "vite/client"],
    "allowSyntheticDefaultImports": true,
    "composite": false,
    "declaration": false,
    "declarationMap": false
  },
  "include": ["src", "vite.config.ts"]
}
