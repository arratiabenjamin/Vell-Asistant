{
  "name": "@forge/gui-mac",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "ensure:dist": "node scripts/ensure-dist.mjs",
    "dev:web": "vite --port 1420 --strictPort",
    "dev": "tauri dev",
    "build:web": "vite build",
    "preview": "vite preview --port 1420 --strictPort",
    "doctor:mac": "tsx scripts/doctor-macos.ts",
    "smoke:mac-clean": "tsx scripts/smoke-clean-macos.ts",
    "setup:rust": "bash scripts/setup-rust-macos.sh",
    "preflight:native": "pnpm doctor:mac && pnpm typecheck",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "clean": "rm -rf dist .vite"
  },
  "dependencies": {
    "@forge/control-plane": "workspace:*",
    "@forge/shared": "workspace:*",
    "@tauri-apps/api": "^2.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.1.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3",
    "vite": "^5.4.9",
    "vite-tsconfig-paths": "^5.0.1"
  }
}
