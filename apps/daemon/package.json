{
  "name": "@forge/daemon",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "types": "dist/main.d.ts",
  "scripts": {
    "dev": "tsx src/main.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "smoke": "node scripts/smoke.mjs",
    "launchd:install": "bash scripts/install-launchd-macos.sh",
    "launchd:uninstall": "bash scripts/uninstall-launchd-macos.sh",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@forge/control-plane": "workspace:*",
    "@forge/engine": "workspace:*",
    "@forge/observability": "workspace:*",
    "@forge/policy": "workspace:*",
    "@forge/shared": "workspace:*",
    "@forge/storage": "workspace:*"
  }
}
